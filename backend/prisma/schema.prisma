// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id              String   @id @default(uuid())
  slug            String   @unique
  name            String
  domain          String?  @unique
  phone           String?
  email           String?
  website         String?
  address         String?
  city            String?
  state           String?
  zip             String?
  logoUrl         String?  @map("logo_url")
  primaryColor    String?  @map("primary_color")
  facebookUrl     String?  @map("facebook_url")
  googleReviewUrl String?  @map("google_review_url")
  vapiAgentId     String?  @map("vapi_agent_id")
  vapiPhoneId     String?  @map("vapi_phone_id")
  clicksendFrom   String?  @map("clicksend_from")
  installerPhone  String?  @map("installer_phone")
  createdAt       DateTime @default(now()) @map("created_at")

  users       User[]
  customers   Customer[]
  quotes      Quote[]
  collections Collection[]
  settings    Setting[]

  @@map("businesses")
}

model User {
  id           String    @id @default(uuid())
  businessId   String?   @map("business_id")
  email        String    @unique
  passwordHash String    @map("password_hash")
  fullname     String?   @map("full_name")
  role         UserRole  @default(INSTALLER)
  phone        String?
  isAvailable  Boolean   @default(true) @map("is_available")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  business Business? @relation(fields: [businessId], references: [id])
  quotes   Quote[]

  @@map("users")
}

enum UserRole {
  INSTALLER
  ADMIN
}

model Collection {
  id          String   @id @default(uuid())
  businessId  String?  @map("business_id")
  name        String
  description String?
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")

  business Business?  @relation(fields: [businessId], references: [id])
  styles   Style[]
  products Product[]
  quotes   Quote[]

  @@unique([businessId, name])
  @@map("collections")
}

model Style {
  id           String   @id @default(uuid())
  collectionId String   @map("collection_id")
  code         String
  name         String
  description  String?
  imageUrl     String?  @map("image_url")
  createdAt    DateTime @default(now()) @map("created_at")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  quotes     Quote[]

  @@unique([collectionId, code])
  @@map("styles")
}

model Product {
  id           String   @id @default(uuid())
  collectionId String   @map("collection_id")
  itemCode     String   @map("item_code")
  description  String
  category     String
  width        Int?
  height       Int?
  depth        Int?
  doors        String?
  msrp         Decimal  @db.Decimal(10, 2)
  price        Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  collection Collection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  quoteItems QuoteItem[]

  @@unique([collectionId, itemCode])
  @@index([collectionId])
  @@index([category])
  @@index([itemCode])
  @@map("products")
}

model Customer {
  id         String   @id @default(uuid())
  businessId String?  @map("business_id")
  firstName  String   @map("first_name")
  lastName   String   @map("last_name")
  email      String
  phone      String
  address    String?
  city       String?
  state      String?
  zipCode    String?  @map("zip_code")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  business     Business?               @relation(fields: [businessId], references: [id])
  quotes       Quote[]
  appointments MeasurementAppointment[]

  @@unique([businessId, email])
  @@map("customers")
}

model Quote {
  id              String      @id @default(uuid())
  businessId      String?     @map("business_id")
  quoteNumber     String      @map("quote_number")
  customerId      String      @map("customer_id")
  userId          String      @map("user_id")
  collectionId    String      @map("collection_id")
  styleId         String      @map("style_id")
  subtotal        Decimal     @db.Decimal(10, 2)  // Wholesale cabinet cost (what we pay)
  taxRate         Decimal     @map("tax_rate") @db.Decimal(5, 4)
  taxAmount       Decimal     @map("tax_amount") @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)  // Client total = clientCabinetPrice + tax
  // Client-facing pricing
  clientCabinetPrice Decimal  @default(0) @map("client_cabinet_price") @db.Decimal(10, 2)  // What we charge customer for cabinets
  // Installer costing fields (internal only)
  installationFee Decimal     @default(0) @map("installation_fee") @db.Decimal(10, 2)  // Our labor cost
  miscExpenses    Decimal     @default(0) @map("misc_expenses") @db.Decimal(10, 2)  // Other internal costs
  msrpTotal       Decimal     @default(0) @map("msrp_total") @db.Decimal(10, 2)  // Retail value for "you save" display
  status          QuoteStatus @default(DRAFT)
  notes           String?     @db.Text
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  sentAt          DateTime?   @map("sent_at")
  expiresAt       DateTime?   @map("expires_at")
  // SMS tracking
  installerPhone        String?   @map("installer_phone")
  installerConfirmed    Boolean   @default(false) @map("installer_confirmed")
  installerConfirmedAt  DateTime? @map("installer_confirmed_at")
  reviewSmsSentAt       DateTime? @map("review_sms_sent_at")
  completedAt           DateTime? @map("completed_at")

  // Lead qualification (captured at quote submission)
  ownsHome         Boolean?  @map("owns_home")
  replacingAll     Boolean?  @map("replacing_all")     // true=yes, null=not sure
  customerTimeline String?   @map("customer_timeline")  // '0-3' | '3-6' | 'exploring'
  isQualified      Boolean   @default(false) @map("is_qualified")

  // Customer SMS engagement
  customerRepliedAt DateTime? @map("customer_replied_at")
  followUpSentAt    DateTime? @map("follow_up_sent_at")

  // Outbound call tracking
  callAttemptedAt DateTime? @map("call_attempted_at")
  callOutcome     String?   @map("call_outcome") // no_answer | scheduled | declined | voicemail

  business      Business?              @relation(fields: [businessId], references: [id])
  customer      Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user          User                   @relation(fields: [userId], references: [id], onDelete: Restrict)
  collection    Collection             @relation(fields: [collectionId], references: [id], onDelete: Restrict)
  style         Style                  @relation(fields: [styleId], references: [id], onDelete: Restrict)
  items         QuoteItem[]
  appointments  MeasurementAppointment[]

  @@unique([businessId, quoteNumber])
  @@index([customerId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("quotes")
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
}

model QuoteItem {
  id         String   @id @default(uuid())
  quoteId    String   @map("quote_id")
  productId  String   @map("product_id")
  quantity   Int
  unitPrice  Decimal  @map("unit_price") @db.Decimal(10, 2)
  lineTotal  Decimal  @map("line_total") @db.Decimal(10, 2)
  roomName   String?  @map("room_name")
  notes      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  quote   Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([quoteId])
  @@map("quote_items")
}

model MeasurementAppointment {
  id          String   @id @default(uuid())
  quoteId     String   @map("quote_id")
  customerId  String   @map("customer_id")
  scheduledAt DateTime @map("scheduled_at")
  notes       String?  @db.Text
  status      String   @default("PENDING") // PENDING | CONFIRMED | COMPLETED | CANCELLED
  source      String   @default("CALL")    // CALL | WEB | ADMIN
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  quote    Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@index([scheduledAt])
  @@map("measurement_appointments")
}

model Setting {
  id         String   @id @default(uuid())
  businessId String?  @map("business_id")
  key        String
  value      String   @db.Text
  updatedAt  DateTime @updatedAt @map("updated_at")

  business Business? @relation(fields: [businessId], references: [id])

  @@unique([businessId, key])
  @@map("settings")
}
